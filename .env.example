# Environment variables for the web_replica Next.js app.
#
# Local development:
#   1. Copy this file to `.env.local` (NOT `.env` — `.env` is committed in
#      this template only to seed the dev default; `.env.local` is git-
#      ignored and takes precedence).
#   2. Edit values to match your local FastAPI backend.
#
# Netlify deployment:
#   Set the SAME variables under Site Configuration → Environment variables.
#   Anything prefixed with NEXT_PUBLIC_ is baked into the client bundle at
#   build time and visible in DevTools — never put secrets there.

# Origin of the FastAPI backend the auth + module pages call into.
#   • Local dev: http://localhost:8000 (or http://127.0.0.1:8000)
#   • Netlify preview: https://api-staging.yourdomain.com
#   • Production: https://api.yourdomain.com
# Leave EMPTY ("") if the backend is mounted on the same origin as the web
# app behind a reverse proxy. The auth library defaults to "" in that case.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
